# Telegram Bot 토큰 (BotFather에서 발급)
# https://t.me/BotFather → /newbot → 안내 따라 생성 후 토큰 복사
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTuvWXyz

# (선택) 권한 가진 chat_id만 받기. 콤마 구분.
# 비워두면 봇을 찾는 누구든 사용 가능. 자기 chat_id 확인:
#   봇에 아무 메시지 보내고 PowerShell 로그에서 [chat_id=...] 확인
ALLOWED_CHAT_IDS=

# LLM 서버 (OpenAI 호환 엔드포인트)
LLM_BASE_URL=http://192.168.0.201:11435/v1

# 사용할 모델. tool calling 잘 되는 모델 권장.
# 추천: qwen3:14b > qwen2.5:latest > qwen3:32b
MODEL_NAME=qwen3:14b

# 단일 LLM 호출 타임아웃 (초). 31B 이상 모델 쓰면 더 늘리기.
LLM_TIMEOUT=300

# 브라우저 헤드리스 모드 (1=숨김, 0=시각화).
BROWSER_HEADLESS=0

# 영구 메모리 DB 경로 (대화 + 사실 저장)
# 비워두면 스크립트 폴더의 agent_memory.db 사용
MEMORY_DB_PATH=

# 스킬 폴더 (skills/*.md 자동 로드)
# 비워두면 스크립트 폴더의 skills/ 사용
SKILLS_DIR=

# 로그 레벨: DEBUG / INFO / WARNING / ERROR
# DEBUG로 두면 LangGraph 내부 동작까지 보임 (시끄러움)
LOG_LEVEL=INFO

# 로그 파일 (회전: 5MB × 5개 보관). 비워두면 agent.log
LOG_FILE=
